# --- Database -------------------------------------------------
# Heroku Postgres connection string — auto-set on Heroku by the addon.
DATABASE_URL=postgres://user:pass@host:5432/dbname

# --- Auth ----------------------------------------------------
# 32+ byte random string used for AES-GCM encryption (Salesforce tokens) and HMAC signing.
# Generate locally with: openssl rand -base64 48
AUTH_SECRET=replace_me_with_a_long_random_string

# Public app URL (used for email links).
APP_URL=http://localhost:3000

# --- LLM (OpenRouter) ----------------------------------------
OPENROUTER_API_KEY=replace_me_with_openrouter_api_key
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# --- Salesforce ----------------------------------------------
# Adoptify uses the same OAuth 2.0 device flow as `sf org login device`,
# with the public CLI client id ("PlatformCLI"). No Connected App or
# Heroku config is required for Salesforce auth.
#
# Optional: override the client id with your own Connected App consumer key.
# SF_CLIENT_ID=
#
# Optional: override the login host for local testing.
# SF_LOGIN_URL=https://login.salesforce.com

# --- Database -------------------------------------------------
# Heroku Postgres connection string — auto-set on Heroku by the addon.
DATABASE_URL=postgres://user:pass@host:5432/dbname

# --- Auth ----------------------------------------------------
# 32+ byte random string used for AES-GCM encryption (Salesforce tokens) and HMAC signing.
# Generate locally with: openssl rand -base64 48
AUTH_SECRET=replace_me_with_a_long_random_string

# Public app URL (used for email links + Salesforce OAuth callback).
APP_URL=http://localhost:3000

# --- LLM (OpenRouter) ----------------------------------------
OPENROUTER_API_KEY=replace_me_with_openrouter_api_key
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# --- Salesforce Connected App --------------------------------
SF_CLIENT_ID=replace_me_with_salesforce_connected_app_consumer_key
SF_CLIENT_SECRET=replace_me_with_salesforce_connected_app_consumer_secret
# Optional override for local testing; production/sandbox OAuth starts always
# use login.salesforce.com or test.salesforce.com based on the button clicked.
SF_LOGIN_URL=https://login.salesforce.com
# This MUST match the Connected App callback URL.
SF_REDIRECT_URI=http://localhost:3000/api/oauth/callback

# Heroku production values should use your deployed app URL:
# APP_URL=https://<your-heroku-app>.herokuapp.com
# SF_REDIRECT_URI=https://<your-heroku-app>.herokuapp.com/api/oauth/callback
#
# Connected App guidance:
# - OAuth scopes: api, refresh_token, openid only
# - IP Relaxation: Relax IP restrictions
# - Do not enable full, write, chatter_api, or custom_permissions

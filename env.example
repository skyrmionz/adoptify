# --- Database -------------------------------------------------
# Heroku Postgres connection string — auto-set on Heroku by the addon.
DATABASE_URL=postgres://user:pass@host:5432/dbname

# --- Auth ----------------------------------------------------
# 32+ byte random string used for AES-GCM encryption (Salesforce tokens) and HMAC signing.
# Generate locally with: openssl rand -base64 48
AUTH_SECRET=replace_me_with_a_long_random_string

# Public app URL (used for email links).
APP_URL=http://localhost:3000

# --- LLM (OpenRouter) ----------------------------------------
OPENROUTER_API_KEY=replace_me_with_openrouter_api_key
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# --- Salesforce Connected App --------------------------------
# Adoptify uses the OAuth 2.0 device flow (same as `sf org login device`).
# No client secret, no callback URL — just the consumer key.
SF_CLIENT_ID=replace_me_with_salesforce_connected_app_consumer_key
# Optional override for local testing.
SF_LOGIN_URL=https://login.salesforce.com

# Connected App requirements:
# - OAuth scopes: api, refresh_token, openid
# - Enable Device Flow: ON
# - Require Secret for Web Server Flow: OFF
# - Require Secret for Refresh Token Flow: OFF
# - IP Relaxation: Relax IP restrictions

# --- Database -------------------------------------------------
# Heroku Postgres connection string — auto-set on Heroku by the addon.
DATABASE_URL=postgres://user:pass@host:5432/dbname

# --- Auth ----------------------------------------------------
# 32+ byte random string used for AES-GCM encryption (Adoptify API tokens) and HMAC signing.
# Generate locally with: openssl rand -base64 48
AUTH_SECRET=replace_me_with_a_long_random_string

# Public app URL (used for email links and embedded into copy-prompt prompts).
APP_URL=http://localhost:3000

# --- LLM (OpenRouter) ----------------------------------------
OPENROUTER_API_KEY=replace_me_with_openrouter_api_key
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# --- Salesforce ----------------------------------------------
# No Salesforce env vars required.
# Adoptify reads orgs through each user's coding agent (Claude Code, Cursor, etc.) —
# the agent runs `sf` CLI locally and POSTs results back via /api/ingest/*.
